<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Read-only FX quote collector (data_platform.collect). No order path.
       Credentials come from the login Keychain-backed environment file loaded
       by the wrapper script — NEVER templated into this plist. -->
  <key>Label</key>
  <string>com.fx-codex.quote-collector</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON__</string>
    <string>__ROOT__/tools/fx_quote_collector.py</string>
    <string>--output-root</string>
    <string>__HOME__/srv/fx-codex/collect</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__ROOT__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <!-- restart on crash, but NOT on config errors (EX_CONFIG=78) or
         token expiry (EX_NOPERM=77): those need a human. -->
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>ThrottleInterval</key>
  <integer>30</integer>
  <key>StandardOutPath</key>
  <string>__HOME__/srv/fx-codex/collect/logs/collector.out.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/srv/fx-codex/collect/logs/collector.err.log</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
