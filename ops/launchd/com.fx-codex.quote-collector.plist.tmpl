<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Read-only FX quote collector. The wrapper loads collector.env at runtime;
       credential values are never templated into this plist. -->
  <key>Label</key>
  <string>com.fx-codex.quote-collector</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>__ROOT__/scripts/run_quote_collector.sh</string>
    <string>--launchd</string>
    <string>--output-root</string>
    <string>__HOME__/srv/fx-codex/collect</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__ROOT__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <!-- The wrapper maps expected operator-action stops (75/77/78) to success,
         so only unexpected failures are restarted. -->
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>ThrottleInterval</key>
  <integer>30</integer>
  <key>StandardOutPath</key>
  <string>__HOME__/srv/fx-codex/collect/logs/collector.out.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/srv/fx-codex/collect/logs/collector.err.log</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
