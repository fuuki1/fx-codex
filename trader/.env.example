# ============================================================================
# trader/.env  — コピーして `.env` を作り、本番値を入れる
#   cp .env.example .env && chmod 600 .env
# .env は絶対にコミットしない（.gitignore 済み）
# ============================================================================

# ---- 取引モード（安全側の既定: paper）------------------------------------
# paper | live
TRADING_MODE=paper
# 本番発注を許可する二重ガード。live にしても ALLOW_LIVE=1 が無ければ発注しない。
ALLOW_LIVE=0

# ---- IBKR / IB Gateway -----------------------------------------------------
TWS_USERID=
TWS_PASSWORD=
# ib-gateway コンテナのモード（paper/live）。compose の ib-gateway に渡る。
VNC_SERVER_PASSWORD=
TWOFA_TIMEOUT_ACTION=restart
AUTO_RESTART_TIME=11:59 PM
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
TIME_ZONE=Asia/Tokyo
# executor が接続する IB Gateway。paper=4002 / live=4001（config が TRADING_MODE で自動選択）
IB_HOST=ib-gateway
IB_CLIENT_ID=11

# ---- データベース（TimescaleDB）-------------------------------------------
POSTGRES_USER=trader
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=trader
DB_HOST=timescaledb
DB_PORT=5432

# ---- Redis -----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Webhook 受信セキュリティ ---------------------------------------------
# TradingView 等の送信元 IP（カンマ区切り）。空にすると IP 検証を無効化（非推奨）。
# TradingView 公式の 4 IP（https://www.tradingview.com/support/solutions/43000529348）。
# 欠落があると正規のアラート（決済シグナル含む）が 403 で捨てられるので注意。
TV_ALLOWED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7
WEBHOOK_SECRET=change-me-webhook-secret

# ---- リスク上限 ------------------------------------------------------------
# 1 注文あたりの数量上限
MAX_POSITION_QTY=10000
# 取引を許可する銘柄（カンマ区切り）。空 = 制限なし（本番では必ず設定すること。
# secret 漏洩や TradingView 設定ミスで任意銘柄・任意資産クラスへ発注されるのを防ぐ）
SYMBOL_ALLOWLIST=USDJPY
# シンボル毎の純建玉上限。同方向シグナルの連打による積み上がりを止める。
# 建玉を減らす方向（決済）の発注は制限しない。
MAX_NET_POSITION_QTY=10000
MAX_DAILY_LOSS_JPY=50000
MAX_ORDERS_PER_MIN=10
# 連続発注エラーがこの回数に達したら自動 Kill switch
MAX_CONSECUTIVE_ERRORS=5
# 取引セッション制御を有効化（FX は 24/5、株は市場時間）
ENFORCE_SESSION=1
# 新規建てシグナルに stop_price / stop_distance を必須化（決済は "close": true で免除）。
# 0 にするとストップ無しの裸ポジションを許すことになるので非推奨。
REQUIRE_STOP_LOSS=1

# ---- 自作戦略（strategy.py）-----------------------------------------------
# 既定 OFF。1 にすると 15 秒ごとに自作ロジックでシグナルを出す。
STRATEGY_ENABLED=0
STRATEGY_SYMBOL=USDJPY
STRATEGY_ASSET=fx
STRATEGY_QTY=1000
STRATEGY_INTERVAL_SEC=15
STRATEGY_PARAMS_FILE=strategy_params.json

# ---- 自律最適化（optimize/auto_optimize.py）-------------------------------
# 最適化に使う「実データ」CSV のパス（必須）。未設定、または同梱サンプル
# （examples/sample_prices.csv = 乱数生成の合成データ）を指すと実行を拒否する。
#OPTIMIZE_DATA=/path/to/real_prices.csv
# 経済イベント CSV（任意）
#OPTIMIZE_EVENTS=/path/to/events.csv

# ---- 通知（Discord）-------------------------------------------------------
DISCORD_WEBHOOK_URL=
# 同一内容アラートの最小再送間隔（秒）。アラート嵐を防ぐ。
NOTIFY_THROTTLE_SEC=300

# ---- ngrok（webhook 公開トンネル）-----------------------------------------
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# ---- ログ ------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
