# ============================================================================
# trader/.env  — コピーして `.env` を作り、本番値を入れる
#   cp .env.example .env && chmod 600 .env
# .env は絶対にコミットしない（.gitignore 済み）
# ============================================================================

# ---- 取引モード（安全側の既定: paper）------------------------------------
# paper | live
TRADING_MODE=paper
# 本番発注を許可する二重ガード。live にしても ALLOW_LIVE=1 が無ければ発注しない。
ALLOW_LIVE=0

# ---- IBKR / IB Gateway -----------------------------------------------------
TWS_USERID=
TWS_PASSWORD=
# ib-gateway コンテナのモード（paper/live）。compose の ib-gateway に渡る。
VNC_SERVER_PASSWORD=
TWOFA_TIMEOUT_ACTION=restart
AUTO_RESTART_TIME=11:59 PM
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
TIME_ZONE=Asia/Tokyo
# executor が接続する IB Gateway。paper=4002 / live=4001（config が TRADING_MODE で自動選択）
IB_HOST=ib-gateway
IB_CLIENT_ID=11

# ---- データベース（TimescaleDB）-------------------------------------------
POSTGRES_USER=trader
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=trader
DB_HOST=timescaledb
DB_PORT=5432

# ---- Redis -----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Webhook 受信セキュリティ ---------------------------------------------
# TradingView 公式の Webhook 送信元 IP（4 つ。カンマ区切り）。空にすると IP 検証無効（非推奨）。
# 参照: TradingView Help「Webhooks」。将来変わりうるので定期確認すること。
TV_ALLOWED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7
WEBHOOK_SECRET=change-me-webhook-secret
# 信頼するプロキシ段数。ngrok 1 段なら 1（XFF 右端＝実クライアント）。直接公開なら 0。
TV_TRUSTED_PROXY_HOPS=1
# 受信ボディの最大バイト数（超過は 413）。
MAX_WEBHOOK_BODY_BYTES=65536
# シグナル最大許容齢（秒, 0 で無効）。alert に "time":"{{timenow}}" を入れた時のみ有効化。
# これより古い／未来すぎる受信は 409 で拒否（リプレイ・遅延配信の発注を防ぐ）。
MAX_SIGNAL_AGE_SEC=120

# ---- リスク上限 ------------------------------------------------------------
MAX_POSITION_QTY=10000
MAX_DAILY_LOSS_JPY=50000
MAX_ORDERS_PER_MIN=10
# 連続発注エラーがこの回数に達したら自動 Kill switch
MAX_CONSECUTIVE_ERRORS=5
# 取引セッション制御を有効化（FX は 24/5、株は市場時間）
ENFORCE_SESSION=1

# ---- プロ級リスクエンジン（risk_engine.py / 詳細は RISK.md）----------------
# サイズは確信ではなくストップ距離×口座リスクで決める（Kovner）。既定 OFF=qty はシグナルのまま。
# 有効化前に ACCOUNT_EQUITY と RISK_VALUE_PER_POINT を必ず実値に合わせること。
RISK_SIZING_ENABLED=0
# 口座残高（口座通貨）。サイジングの基準。定期的に実残高へ更新する。
ACCOUNT_EQUITY=1000000
# 1 取引で許容する口座割合（%）。個人目安: 初心者 0.25–0.5、慣れても 0.75 上限。
RISK_PER_TRADE_PCT=0.5
# True(1) で stop 距離の無いシグナルを却下（サイジングを必須化）。
REQUIRE_STOP_FOR_SIZING=0
# 発注ロットの最小刻みと最小ロット（これ未満になるサイズは発注しない）。
LOT_STEP=1000
MIN_LOT=1000
# 価格 1.0 動いたときの「1 単位あたり損益（口座通貨）」。JPY 建てペア×JPY 口座は 1.0。
# 例: "EURUSD=150.0,GBPUSD=190.0"（未指定の銘柄は 1.0）。
RISK_VALUE_PER_POINT=
# 週次実現損失の上限（0=無効）。超過で自動 Kill switch（翌週まで新規停止・手動解除）。
MAX_WEEKLY_LOSS_JPY=0
# 日次/週次損失の集計境界の timezone（既定 JST）。UTC のままだと 09:00 JST でリセットし
# 境界跨ぎで日次上限が緩くなるため、取引日に合わせる。IANA 名（例: Asia/Tokyo, UTC）。
RISK_DAY_TIMEZONE=Asia/Tokyo
# 連敗スロットル（Lipschutz: 連敗時はサイズ縮小→停止）
LOSS_STREAK_REDUCE_AT=3
LOSS_STREAK_REDUCE_FACTOR=0.5
LOSS_STREAK_HALT_AT=5
RECENT_TRADES_WINDOW=50
# 同時に持てる別銘柄数（0=無効）。「最大 3 つ」。
MAX_CONCURRENT_POSITIONS=3
# 1 通貨あたりの純エクスポージャ上限（0=無効）。高相関ポジションを 1 つとして合算。
MAX_CURRENCY_EXPOSURE=0
# 重要指標ブラックアウト窓の定義ファイル（無ければ無効）。example をコピーして運用。
#   cp app/risk_calendar.example.json app/risk_calendar.json
RISK_BLACKOUT_FILE=risk_calendar.json

# ---- プロ級リスクエンジン 第2層（非対称性・規律・DD・薄商い / 既定 OFF）----
# 報酬/リスク比の下限（0=無効）。シグナルに利確距離(take_profit/tp_distance/target)がある時のみ評価。
MIN_REWARD_RISK=0
# 1 で利確目標の無いシグナルを却下（R:R を必須化）。
REQUIRE_TARGET_FOR_RR=0
# 1 で根拠(reason/comment)の無いシグナルを却下（理由を文章化できないなら入らない）。
REQUIRE_REASON=0
# 全期間の累計実現損益の高値からのドローダウンが口座の何%で自動 Kill switch（0=無効）。
MAX_DRAWDOWN_PCT=0
# 薄商い時間帯（UTC, "HH:MM-HH:MM" カンマ区切り）。新規を抑止。例: FX ロールオーバ 20:55-22:05。
THIN_LIQUIDITY_WINDOWS=

# ---- 自作戦略（strategy.py）-----------------------------------------------
# 既定 OFF。1 にすると 15 秒ごとに自作ロジックでシグナルを出す。
STRATEGY_ENABLED=0
STRATEGY_SYMBOL=USDJPY
STRATEGY_ASSET=fx
STRATEGY_QTY=1000
STRATEGY_INTERVAL_SEC=15
STRATEGY_PARAMS_FILE=strategy_params.json

# ---- 通知（Discord）-------------------------------------------------------
DISCORD_WEBHOOK_URL=
# 同一内容アラートの最小再送間隔（秒）。アラート嵐を防ぐ。
NOTIFY_THROTTLE_SEC=300

# ---- ngrok（webhook 公開トンネル）-----------------------------------------
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# ---- ログ ------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
