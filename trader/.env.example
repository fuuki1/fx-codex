# ============================================================================
# trader/.env  — コピーして `.env` を作り、本番値を入れる
#   cp .env.example .env && chmod 600 .env
# .env は絶対にコミットしない（.gitignore 済み）
# ============================================================================

# ---- 取引モード（安全側の既定: paper）------------------------------------
# paper | live
TRADING_MODE=paper
# 本番発注を許可する二重ガード。live にしても ALLOW_LIVE=1 が無ければ発注しない。
ALLOW_LIVE=0

# ---- IBKR / IB Gateway -----------------------------------------------------
TWS_USERID=
TWS_PASSWORD=
# ib-gateway コンテナのモード（paper/live）。compose の ib-gateway に渡る。
VNC_SERVER_PASSWORD=
TWOFA_TIMEOUT_ACTION=restart
AUTO_RESTART_TIME=11:59 PM
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
TIME_ZONE=Asia/Tokyo
# executor が接続する IB Gateway。paper=4002 / live=4001（config が TRADING_MODE で自動選択）
IB_HOST=ib-gateway
IB_CLIENT_ID=11

# ---- データベース（TimescaleDB）-------------------------------------------
POSTGRES_USER=trader
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=trader
DB_HOST=timescaledb
DB_PORT=5432

# ---- Redis -----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Webhook 受信セキュリティ ---------------------------------------------
# TradingView 等の送信元 IP（カンマ区切り）。空にすると IP 検証を無効化（非推奨）。
# TradingView 公式の 4 IP（https://www.tradingview.com/support/solutions/43000529348）。
# 欠落があると正規のアラート（決済シグナル含む）が 403 で捨てられるので注意。
TV_ALLOWED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7
WEBHOOK_SECRET=change-me-webhook-secret

# ---- リスク上限 ------------------------------------------------------------
# 1 注文あたりの数量上限
MAX_POSITION_QTY=10000
# 取引を許可する銘柄（カンマ区切り）。空 = 制限なし（本番では必ず設定すること。
# secret 漏洩や TradingView 設定ミスで任意銘柄・任意資産クラスへ発注されるのを防ぐ）
SYMBOL_ALLOWLIST=USDJPY
# シンボル毎の純建玉上限。同方向シグナルの連打による積み上がりを止める。
# 建玉を減らす方向（決済）の発注は制限しない。
MAX_NET_POSITION_QTY=10000
MAX_DAILY_LOSS_JPY=50000
MAX_ORDERS_PER_MIN=10
# 連続発注エラーがこの回数に達したら自動 Kill switch
MAX_CONSECUTIVE_ERRORS=5
# 取引セッション制御を有効化（FX は 24/5、株は市場時間）
ENFORCE_SESSION=1
# 新規建てシグナルに stop_price / stop_distance を必須化（決済は "close": true で免除）。
# 0 にするとストップ無しの裸ポジションを許すことになるので非推奨。
REQUIRE_STOP_LOSS=1

# ---- プロ級リスクエンジン（risk_engine.py, 既存チェックへの追加層）----------
# off=評価しない（既定・従来と完全同一） / shadow=判断をログに残すだけ / enforce=適用。
# 昇格手順: off → shadow で risk_engine_decision ログを確認 → enforce。
RISK_ENGINE_MODE=off
# サイジング（有効化前に ACCOUNT_EQUITY と RISK_VALUE_PER_POINT を実値に合わせること）
RISK_SIZING_ENABLED=0
ACCOUNT_EQUITY=1000000
RISK_PER_TRADE_PCT=0.5
# 例: RISK_VALUE_PER_POINT=USDJPY=1.0,EURJPY=1.0（未指定銘柄は 1.0）
#RISK_VALUE_PER_POINT=
# 週次損失上限（0 で無効）・DD 停止（口座の%、0 で無効）
MAX_WEEKLY_LOSS_JPY=0
MAX_DRAWDOWN_PCT=0
# 連敗スロットル: 3 連敗でサイズ半減、5 連敗で新規停止（Kill switch）
LOSS_STREAK_REDUCE_AT=3
LOSS_STREAK_REDUCE_FACTOR=0.5
LOSS_STREAK_HALT_AT=5
# 同時保有銘柄数の上限（0 で無効）・1 通貨あたり純エクスポージャ上限（0 で無効）
MAX_CONCURRENT_POSITIONS=3
MAX_CURRENCY_EXPOSURE=0
# 重要指標ブラックアウト窓（app/risk_calendar.example.json を参照して配置。無ければ無効）
RISK_BLACKOUT_FILE=risk_calendar.json
# 薄商い時間帯（UTC "HH:MM-HH:MM" カンマ区切り。例: FX ロールオーバ 20:55-22:05）
#THIN_LIQUIDITY_WINDOWS=20:55-22:05
# 報酬/リスク比の下限（0 で無効。シグナルに tp_distance がある時のみ評価）
MIN_REWARD_RISK=0

# ---- 自作戦略（strategy.py）-----------------------------------------------
# 既定 OFF。1 にすると 15 秒ごとに自作ロジックでシグナルを出す。
STRATEGY_ENABLED=0
STRATEGY_SYMBOL=USDJPY
STRATEGY_ASSET=fx
STRATEGY_QTY=1000
STRATEGY_INTERVAL_SEC=15
STRATEGY_PARAMS_FILE=strategy_params.json
# 価格バーの間隔（秒）。取得本数は slow_window から逆算するので、ここはバーの時間軸のみ。
# 許容: 5/10/15/30, 60(1分)/300(5分)/900(15分)/1800(30分)/3600(1時間)。
STRATEGY_BAR_SIZE_SEC=5

# ---- 自律最適化（optimize/auto_optimize.py）-------------------------------
# 最適化に使う「実データ」CSV のパス（必須）。未設定、または同梱サンプル
# （examples/sample_prices.csv = 乱数生成の合成データ）を指すと実行を拒否する。
#OPTIMIZE_DATA=/path/to/real_prices.csv
# 経済イベント CSV（任意）
#OPTIMIZE_EVENTS=/path/to/events.csv

# ---- 通知（Discord）-------------------------------------------------------
DISCORD_WEBHOOK_URL=
# 同一内容アラートの最小再送間隔（秒）。アラート嵐を防ぐ。
NOTIFY_THROTTLE_SEC=300

# ---- ngrok（webhook 公開トンネル）-----------------------------------------
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# ---- ログ ------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
